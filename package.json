{
  "name": "chaser-bot",
  "version": "0.1.0",
  "description": "GrandChase Discord bot",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "prestart": "prisma generate && prisma migrate deploy",
    "start": "node dist/main.js",
    "deploy:commands": "tsx scripts/deploy-commands.ts",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "discord.js": "^14.16.3",
    "dotenv": "^17.4.2",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
